{
  "name": "@repo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node scripts/copy-static-assets.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "RUN_API_INTEGRATION_TESTS=1 vitest run",
    "test:unit": "vitest run",
    "test:integration": "RUN_API_INTEGRATION_TESTS=1 vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "reset-password": "tsx prisma/reset-password.ts",
    "create-superadmin": "tsx prisma/create-superadmin.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@casl/ability": "^6.7.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@prisma/client": "5.22.0",
    "@repo/schemas": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/utils": "workspace:*",
    "@types/pdfkit": "^0.17.5",
    "argon2": "^0.40.0",
    "bullmq": "^5.0.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.0",
    "fastify-type-provider-zod": "^2.0.0",
    "ioredis": "^5.4.0",
    "pdfkit": "^0.18.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "resend": "^3.4.0",
    "zod": "^3.23.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^17.4.1",
    "eslint": "^8.57.0",
    "prisma": "5.22.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
