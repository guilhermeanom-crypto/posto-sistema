  @@index([tenantId, empreendimentoId, ativo])
  @@index([tenantId, cargo, ativo])
  @@map("funcionarios")
}

// ─────────────────────────────────────────────────────────────────────────────
// SST — TREINAMENTOS
// ─────────────────────────────────────────────────────────────────────────────

model TreinamentoTipo {
  id                    String   @id @default(uuid())
  tenantId              String   @map("tenant_id")
  nome                  String
  normativa             String // NR-20 | NR-35 | NR-10 | NR-12 | CIPA | BRIGADA | OUTROS
  cargaHoraria          Int      @map("carga_horaria") // horas
  periodicidadeMeses    Int      @map("periodicidade_meses") // 0 = único, 12 = anual, 24 = bienal
  obrigatorioParaCargos String[] @map("obrigatorio_para_cargos")
  conteudoProgramatico  String[] @map("conteudo_programatico")
  ativo                 Boolean  @default(true)
  criadoEm              DateTime @default(now()) @map("criado_em")

  tenant    Tenant                @relation(fields: [tenantId], references: [id])
  execucoes TreinamentoExecucao[]

  @@unique([tenantId, nome, normativa])
  @@index([tenantId, ativo])
  @@map("treinamento_tipos")
}

model TreinamentoExecucao {
  id                     String    @id @default(uuid())
  tenantId               String    @map("tenant_id")
  empreendimentoId       String    @map("empreendimento_id")
  tipoId                 String    @map("tipo_id")
  instrutor              String?
  cargaHorariaRealizada  Int?      @map("carga_horaria_realizada")
  dataRealizacao         DateTime  @map("data_realizacao") @db.Date
  dataVencimento         DateTime? @map("data_vencimento") @db.Date
  status                 String    @default("REALIZADO") // AGENDADO | REALIZADO | VENCIDO | CANCELADO
  local                  String?
  certificadoChaveS3     String?   @map("certificado_chave_s3")
  certificadoNomeArquivo String?   @map("certificado_nome_arquivo")
  observacoes            String?
  criadoEm               DateTime  @default(now()) @map("criado_em")
  atualizadoEm           DateTime  @updatedAt @map("atualizado_em")

  tipo           TreinamentoTipo           @relation(fields: [tipoId], references: [id])
  empreendimento Empreendimento            @relation(fields: [empreendimentoId], references: [id])
  participantes  TreinamentoParticipante[]

  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, dataVencimento, status])
  @@map("treinamento_execucoes")
}

model TreinamentoParticipante {
  id             String   @id @default(uuid())
  execucaoId     String   @map("execucao_id")
  funcionarioId  String   @map("funcionario_id")
  presenca       Boolean  @default(true)
  aprovado       Boolean  @default(true)
  certificadoUrl String?  @map("certificado_url")
  criadoEm       DateTime @default(now()) @map("criado_em")

  execucao    TreinamentoExecucao @relation(fields: [execucaoId], references: [id], onDelete: Cascade)
  funcionario Funcionario         @relation(fields: [funcionarioId], references: [id])

  @@unique([execucaoId, funcionarioId])
  @@index([funcionarioId])
  @@map("treinamento_participantes")
}

// ─────────────────────────────────────────────────────────────────────────────
// SST — EPI (Equipamento de Proteção Individual)
// ─────────────────────────────────────────────────────────────────────────────

model EntregaEPI {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  empreendimentoId  String    @map("empreendimento_id")
  funcionarioId     String    @map("funcionario_id")
  tipoEPI           String    @map("tipo_epi") // Calçado | Luva | Óculos | Capacete | etc.
  ca                String? // nº Certificado de Aprovação MTE
  quantidade        Int       @default(1)
  dataEntrega       DateTime  @map("data_entrega") @db.Date
  dataVencimento    DateTime? @map("data_vencimento") @db.Date
  status            String    @default("VIGENTE") // VIGENTE | VENCIDO | DEVOLVIDO
  assinaturaChaveS3 String?   @map("assinatura_chave_s3")
  observacoes       String?
  criadoEm          DateTime  @default(now()) @map("criado_em")

  funcionario    Funcionario    @relation(fields: [funcionarioId], references: [id])
  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id])

  @@index([tenantId, empreendimentoId, funcionarioId])
  @@index([tenantId, dataVencimento, status])
  @@map("entregas_epi")
}

model ASO {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  empreendimentoId  String    @map("empreendimento_id")
  funcionarioId     String?   @map("funcionario_id")
  funcionarioNome   String    @map("funcionario_nome")
  funcionarioCPF    String?   @map("funcionario_cpf")
  cargo             String?
  tipo              String // ADMISSIONAL | PERIODICO | DEMISSIONAL | RETORNO | MUDANCA_FUNCAO
  dataExame         DateTime  @map("data_exame") @db.Date
  dataVencimento    DateTime? @map("data_vencimento") @db.Date
  aptidao           String // APTO | INAPTO | APTO_RESTRICOES
  medicoResponsavel String?   @map("medico_responsavel")
  chaveS3           String?   @map("chave_s3")
  nomeArquivo       String?   @map("nome_arquivo")
  observacoes       String?
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")

  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id])
  funcionario    Funcionario?   @relation(fields: [funcionarioId], references: [id])

  @@index([tenantId, empreendimentoId])
  @@index([tenantId, dataVencimento, aptidao])
  @@map("asos")
}

model DocumentoSST {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  empreendimentoId String    @map("empreendimento_id")
  tipo             String // PCMSO | PPRA | PGR | LTCAT | LAUDO_ERGONOMICO | PPCI_SST | OUTROS
  responsavel      String? // médico / engenheiro responsável
  dataElaboracao   DateTime? @map("data_elaboracao") @db.Date
  dataVencimento   DateTime? @map("data_vencimento") @db.Date
  status           String    @default("VIGENTE") // VIGENTE | A_RENOVAR | VENCIDO
  chaveS3          String?   @map("chave_s3")
  nomeArquivo      String?   @map("nome_arquivo")
  observacoes      String?
  criadoEm         DateTime  @default(now()) @map("criado_em")
  atualizadoEm     DateTime  @updatedAt @map("atualizado_em")

  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id])

  @@index([tenantId, empreendimentoId, tipo])
  @@index([tenantId, dataVencimento, status])
  @@map("documentos_sst")
}

// ─────────────────────────────────────────────────────────────────────────────
// M6 — ANP / INMETRO: BOMBAS E CALIBRAÇÃO
