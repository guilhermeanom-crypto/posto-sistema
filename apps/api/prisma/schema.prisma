}

model FollowUpLead {
  id          String       @id @default(uuid())
  leadId      String       @map("lead_id")
  autorId     String?      @map("autor_id")
  tipo        TipoFollowUp
  notas       String?      @db.Text
  realizadoEm DateTime     @map("realizado_em")
  criadoEm    DateTime     @default(now()) @map("criado_em")

  lead LeadWhatsApp @relation(fields: [leadId], references: [id])

  @@index([leadId, realizadoEm])
  @@map("followups_lead")
}

enum EstagioCRM {
  NOVO
  CONTATADO
  PROPOSTA_ENVIADA
  NEGOCIACAO
  GANHO
  PERDIDO
}

enum TipoFollowUp {
  LIGACAO
  EMAIL
  WHATSAPP
  VISITA
  REUNIAO
  OUTROS
}

model MensagemLead {
  id       String   @id @default(uuid())
  leadId   String   @map("lead_id")
  direcao  String // ENVIADA | RECEBIDA
  conteudo String   @db.Text
  criadoEm DateTime @default(now()) @map("criado_em")

  lead LeadWhatsApp @relation(fields: [leadId], references: [id])

  @@index([leadId, criadoEm])
  @@map("mensagens_lead")
}

// ─────────────────────────────────────────────────────────────────────────────
// M15 — CHECKLISTS OPERACIONAIS
// ─────────────────────────────────────────────────────────────────────────────

model ChecklistTemplate {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  nome          String
  descricao     String?
  modulo        String // AMBIENTAL | SST | OPERACIONAL | ANP | ESTANQUEIDADE | GERAL
  periodicidade String // DIARIO | SEMANAL | MENSAL | TRIMESTRAL | ANUAL
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  itens     ChecklistItem[]
  execucoes ChecklistExecucao[]

  @@index([tenantId, modulo, ativo])
  @@map("checklist_templates")
}

model ChecklistItem {
  id          String  @id @default(uuid())
  templateId  String  @map("template_id")
  ordem       Int
  descricao   String
  obrigatorio Boolean @default(true)
  categoria   String? // agrupamento visual dentro do checklist

  template  ChecklistTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  respostas ChecklistResposta[]

  @@index([templateId, ordem])
  @@map("checklist_itens")
}

model ChecklistExecucao {
  id               String    @id @default(uuid())
  templateId       String    @map("template_id")
  tenantId         String    @map("tenant_id")
  empreendimentoId String    @map("empreendimento_id")
  executadoPorId   String    @map("executado_por_id")
  status           String    @default("EM_ANDAMENTO") // EM_ANDAMENTO | CONFORME | NAO_CONFORME | PARCIAL
  iniciadaEm       DateTime  @default(now()) @map("iniciada_em")
  finalizadaEm     DateTime? @map("finalizada_em")
  observacoes      String?

  template       ChecklistTemplate   @relation(fields: [templateId], references: [id])
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  empreendimento Empreendimento      @relation(fields: [empreendimentoId], references: [id])
  executadoPor   Usuario             @relation(fields: [executadoPorId], references: [id])
  respostas      ChecklistResposta[]

  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, templateId, iniciadaEm])
  @@map("checklist_execucoes")
}

model ChecklistResposta {
  id         String  @id @default(uuid())
  execucaoId String  @map("execucao_id")
  itemId     String  @map("item_id")
  status     String // OK | ATENCAO | CRITICO | NA
  observacao String?

  execucao ChecklistExecucao @relation(fields: [execucaoId], references: [id], onDelete: Cascade)
  item     ChecklistItem     @relation(fields: [itemId], references: [id])

  @@unique([execucaoId, itemId])
  @@index([execucaoId])
  @@map("checklist_respostas")
}

// ─────────────────────────────────────────────────────────────────────────────
// CATÁLOGO DE OBRIGAÇÕES REGULATÓRIAS
// Tabela de referência global (não multi-tenant) que define quais obrigações
// se aplicam a cada tipo de empreendimento, por módulo e UF.
// Usada pelo onboarding inteligente para gap analysis automático.
// ─────────────────────────────────────────────────────────────────────────────

model ObrigacaoRegulatoriaBase {
  id                 String            @id @default(uuid())
  codigo             String            @unique
  // 'revendedor' | 'distribuidor' | 'transportador' | 'todos'
  tipoEmpreendimento String            @map("tipo_empreendimento")
  // null = obrigação federal/nacional; 'SP', 'MG', etc = obrigação estadual
  uf                 String?
  // 'AMBIENTAL' | 'SST' | 'ANP' | 'URBANISTICO' | 'MONITORAMENTO' | 'LOGISTICA_REVERSA'
  modulo             String
  descricao          String
  fundamentoLegal    String?           @map("fundamento_legal")
  // 'UNICA' | 'MENSAL' | 'TRIMESTRAL' | 'SEMESTRAL' | 'ANUAL' | 'BIENAL' | 'QUINQUENAL'
  periodicidade      String
  // Referência descritiva ao tipo de documento que comprova o cumprimento
  tipoDocumentoRef   String?           @map("tipo_documento_ref")
  // 'CRITICA' | 'ALTA' | 'MEDIA'
  criticidade        String
  diasAlertaAntes    Int[]             @default([90, 60, 30]) @map("dias_alerta_antes")
  observacoes        String?
  ativo              Boolean           @default(true)
  criadoEm           DateTime          @default(now()) @map("criado_em")
  atualizadoEm       DateTime          @updatedAt @map("atualizado_em")
  servicosCatalogo   ServicoCatalogo[]

  @@index([tipoEmpreendimento, uf, ativo])
  @@index([modulo, ativo])
  @@map("obrigacoes_regulatorias_base")
}

model ServicoCatalogo {
  id                  String  @id @default(uuid())
  codigo              String  @unique
  nome                String
  descricao           String
  categoria           String
  subcategoria        String?
  horasTecnicasBase   Decimal @default(8) @map("horas_tecnicas_base") @db.Decimal(10, 2)
  fatorComplexidade   Decimal @default(1) @map("fator_complexidade") @db.Decimal(6, 2)
  valorReferenciaHora Decimal @default(180) @map("valor_referencia_hora") @db.Decimal(12, 2)
  obrigacaoBaseId     String? @map("obrigacao_base_id")
  obrigacaoBaseCodigo String? @map("obrigacao_base_codigo")

  precoBase            Decimal? @map("preco_base") @db.Decimal(12, 2)
  precoMinimo          Decimal? @map("preco_minimo") @db.Decimal(12, 2)
  precoMaximo          Decimal? @map("preco_maximo") @db.Decimal(12, 2)
  custoInternoEstimado Decimal? @map("custo_interno_estimado") @db.Decimal(12, 2)
  margemLucroAlvo      Decimal? @map("margem_lucro_alvo") @db.Decimal(6, 2)
  recorrente           Boolean  @default(false)
  mesesRecorrencia     Int?     @map("meses_recorrencia")

  metadata     Json?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  obrigacaoBase ObrigacaoRegulatoriaBase? @relation(fields: [obrigacaoBaseId], references: [id])
  itensProposta ItemProposta[]

  @@index([categoria, ativo])
  @@index([obrigacaoBaseId, ativo])
  @@index([obrigacaoBaseCodigo, ativo])
  @@map("servicos_consultoria_base")
}

model PoliticaPrecificacaoDiagnostico {
