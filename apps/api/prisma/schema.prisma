  impacto        String? // ALTO | MEDIO | BAIXO
  resumoIA       String?  @map("resumo_ia") @db.Text
  notificado     Boolean  @default(false)
  criadoEm       DateTime @default(now()) @map("criado_em")

  @@unique([fonte, dataPublicacao, url])
  @@index([dataPublicacao, relevante])
  @@index([relevante, notificado])
  @@map("publicacoes_do")
}

