// ─────────────────────────────────────────────────────────────────────────────
// G1 — FUNDAÇÃO (sem dependências externas)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id                    String       @id @default(uuid())
  nome                  String
  slug                  String       @unique
  plano                 PlanoTenant  @default(STARTER)
  status                StatusTenant @default(ATIVO)
  limiteEmpreendimentos Int          @default(100) @map("limite_empreendimentos")
  configuracoes         Json         @default("{}")
  ativo                 Boolean      @default(true)
  dataAtivacao          DateTime?    @map("data_ativacao")
  dataExpiracao         DateTime?    @map("data_expiracao")
  criadoEm              DateTime     @default(now()) @map("criado_em")
  atualizadoEm          DateTime     @updatedAt @map("atualizado_em")

  // Relacionamentos
  usuarios                        Usuario[]
  empresas                        Empresa[]
  orgaos                          OrgaoRegulador[]
  tiposProcesso                   TipoProcesso[]
  tiposDocumento                  TipoDocumento[]
  regrasAutomaticas               RegraAutomatica[]
  alertas                         Alerta[]
  transportadoras                 Transportadora[]
  contatosWhatsApp                ContatoWhatsApp[]
  mensagensWhatsApp               MensagemWhatsApp[]
  leadsWhatsApp                   LeadWhatsApp[]
  checklistTemplates              ChecklistTemplate[]
  checklistExecucoes              ChecklistExecucao[]
  metasResiduos                   MetaResiduoAnual[]
  ccrs                            CCR[]
  limitesParametros               LimiteParametro[]
  treinamentoTipos                TreinamentoTipo[]
  politicaPrecificacaoDiagnostico PoliticaPrecificacaoDiagnostico?
  diagnosticosComerciais          DiagnosticoComercial[]
  propostasComerciais             PropostaComercial[]
  handoffsComerciais              HandoffComercial[]
  itensProposta                   ItemProposta[]
  contratos                       Contrato[]
  ordensServico                   OrdemServico[]
  entregaveis                     Entregavel[]
  pendenciasCampo                 PendenciaCampo[]
  evidenciasCampo                 EvidenciaCampo[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// G2 — USUÁRIOS E ACESSO
// ─────────────────────────────────────────────────────────────────────────────

model Usuario {
  id                    String        @id @default(uuid())
  tenantId              String        @map("tenant_id")
  nome                  String
  email                 String
  senhaHash             String        @map("senha_hash")
  perfil                PerfilUsuario
  telefone              String?
  ativo                 Boolean       @default(true)
  emailVerificado       Boolean       @default(false) @map("email_verificado")
  ultimoAcesso          DateTime?     @map("ultimo_acesso")
  tentativasLoginFalhas Int           @default(0) @map("tentativas_login_falhas")
  bloqueadoAte          DateTime?     @map("bloqueado_ate")
  configuracoes         Json          @default("{}")
  criadoEm              DateTime      @default(now()) @map("criado_em")
  atualizadoEm          DateTime      @updatedAt @map("atualizado_em")
  inativadoEm           DateTime?     @map("inativado_em")
  inativadoPorId        String?       @map("inativado_por_id")

  // Relacionamentos
  tenant                         Tenant                  @relation(fields: [tenantId], references: [id])
  empreendimentosAcesso          EmpreendimentoAcesso[]
  sessoes                        SessaoRefresh[]
  tokensPortalGerados            TokenPortal[]           @relation("TokenGeradoPor")
  tarefasResponsavel             Tarefa[]                @relation("TarefaResponsavel")
  tarefasCriadas                 Tarefa[]                @relation("TarefaCriador")
  tarefasEscalonadas             Tarefa[]                @relation("TarefaEscalonada")
  versoesEnviadas                DocumentoVersao[]       @relation("VersaoEnviador")
  versoesValidadas               DocumentoVersao[]       @relation("VersaoValidador")
  processoResponsavel            Processo[]
  condicionantesResponsavel      Condicionante[]         @relation("CondicionanteResponsavel")
  condicionantesDispensadas      Condicionante[]         @relation("CondicionanteDispensadaPor")
  ciclosCumpridos                CicloCondicionante[]
  requisitosDispensados          RequisitoProcesso[]
  historicoFases                 HistoricoFaseProcesso[]
  alertasDestinatario            AlertaDestinatario[]
  auditLogs                      AuditLog[]
  checklistExecucoes             ChecklistExecucao[]
  equipHistCriados               EquipamentoHistorico[]  @relation("EquipHistCriador")
  diagnosticosComerciais         DiagnosticoComercial[]  @relation("DiagnosticoComercialCriador")
  propostasComerciaisCriadas     PropostaComercial[]     @relation("PropostaComercialCriador")
  propostasComerciaisAtualizadas PropostaComercial[]     @relation("PropostaComercialAtualizador")
  handoffsComerciaisCriados      HandoffComercial[]      @relation("HandoffComercialCriador")
  handoffsComerciaisComercial    HandoffComercial[]      @relation("HandoffComercialResponsavelComercial")
  handoffsComerciaisOperacional  HandoffComercial[]      @relation("HandoffComercialResponsavelOperacional")
  contratosCriados               Contrato[]              @relation("ContratoCriador")
  contratosAtualizados           Contrato[]              @relation("ContratoAtualizador")
  osResponsavel                  OrdemServico[]          @relation("OSResponsavel")
  osCriadas                      OrdemServico[]          @relation("OSCriador")
  osAtualizadas                  OrdemServico[]          @relation("OSAtualizador")
  pendenciasCriadas              PendenciaCampo[]        @relation("PendenciaCriador")
  pendenciasResponsavel          PendenciaCampo[]        @relation("PendenciaResponsavel")
  evidenciasCapturadas           EvidenciaCampo[]        @relation("EvidenciaCapturador")
  evidenciasValidadas            EvidenciaCampo[]        @relation("EvidenciaValidador")
  entregaveisCriados             Entregavel[]            @relation("EntregavelCriador")
  entregaveisAtualizados         Entregavel[]            @relation("EntregavelAtualizador")

  @@unique([tenantId, email])
  @@index([tenantId, ativo])
  @@map("usuarios")
}

model SessaoRefresh {
  id              String    @id @default(uuid())
  usuarioId       String    @map("usuario_id")
  tokenHash       String    @unique @map("token_hash")
  ip              String
  userAgent       String    @map("user_agent")
  expiresAt       DateTime  @map("expires_at")
  revogadoEm      DateTime? @map("revogado_em")
  motivoRevogacao String?   @map("motivo_revogacao")
  criadoEm        DateTime  @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([expiresAt])
  @@map("sessoes_refresh")
}

model TokenPortal {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  empreendimentoId  String    @map("empreendimento_id")
  solicitadoPorId   String    @map("solicitado_por_id")
  emailDestinatario String    @map("email_destinatario")
  nomeContato       String?   @map("nome_contato")
  token             String    @unique
  expiresAt         DateTime  @map("expires_at")
  usadoEm           DateTime? @map("usado_em")
  criadoEm          DateTime  @default(now()) @map("criado_em")

  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id])
  solicitadoPor  Usuario        @relation("TokenGeradoPor", fields: [solicitadoPorId], references: [id])

  @@index([empreendimentoId])
  @@map("tokens_portal")
}

// ─────────────────────────────────────────────────────────────────────────────
// G3 — ESTRUTURA ORGANIZACIONAL
// ─────────────────────────────────────────────────────────────────────────────

model Empresa {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  nome               String
  razaoSocial        String   @map("razao_social")
  cnpj               String
  inscricaoEstadual  String?  @map("inscricao_estadual")
  inscricaoMunicipal String?  @map("inscricao_municipal")
  ativo              Boolean  @default(true)
  criadoEm           DateTime @default(now()) @map("criado_em")
  atualizadoEm       DateTime @updatedAt @map("atualizado_em")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  empreendimentos Empreendimento[]

  @@unique([tenantId, cnpj])
  @@index([tenantId, ativo])
  @@map("empresas")
}

model Empreendimento {
  id                      String    @id @default(uuid())
  tenantId                String    @map("tenant_id")
  empresaId               String    @map("empresa_id")
  nome                    String
  nomeFantasia            String?   @map("nome_fantasia")
  cnpj                    String?
  codigoInterno           String?   @map("codigo_interno")
  bandeira                String?
  tipo                    String?
  logradouro              String
  numero                  String
  complemento             String?
  bairro                  String
  cidade                  String
  estado                  String    @db.Char(2)
  cep                     String
  latitude                Decimal?  @db.Decimal(10, 8)
  longitude               Decimal?  @db.Decimal(11, 8)
  responsavelTecnicoNome  String?   @map("responsavel_tecnico_nome")
  responsavelTecnicoCrea  String?   @map("responsavel_tecnico_crea")
  responsavelTecnicoEmail String?   @map("responsavel_tecnico_email")
  contatoEmail            String?   @map("contato_email")
  contatoTelefone         String?   @map("contato_telefone")
  atividades              String[]
  dataInicioOperacao      DateTime? @map("data_inicio_operacao") @db.Date
  ativo                   Boolean   @default(true)
  criadoEm                DateTime  @default(now()) @map("criado_em")
  atualizadoEm            DateTime  @updatedAt @map("atualizado_em")

  empresa                Empresa                 @relation(fields: [empresaId], references: [id])
  acessosUsuario         EmpreendimentoAcesso[]
  processos              Processo[]
  documentos             Documento[]
  condicionantes         Condicionante[]
  tarefas                Tarefa[]
  alertas                Alerta[]
  tokensPortal           TokenPortal[]
  snapshotsCompliance    ComplianceSnapshot[]
  licencasAmbientais     LicencaAmbiental[]
  alvarasUrbanisticos    AlvaraUrbanistico[]
  funcionarios           Funcionario[]
  asos                   ASO[]
  documentosSST          DocumentoSST[]
  bombas                 BombaAbastecimento[]
  tanques                Tanque[]
  mtrs                   MTR[]
  pocosArtesianos        PocoArtesiano[]
  campanhasMonitoramento CampanhaMonitoramento[]
  pocosMonitoramento     PocoMonitoramento[]
  autosInfracao          AutoInfracao[]
  scoresRisco            ScoreRisco[]
  contatosWhatsApp       ContatoWhatsApp[]
  checklistExecucoes     ChecklistExecucao[]
  metasResiduos          MetaResiduoAnual[]
  treinamentoExecucoes   TreinamentoExecucao[]
  entregasEPI            EntregaEPI[]
  mensagensPortal        MensagemPortal[]
  pgrs                   PGRS[]
  equipamentoHistoricos  EquipamentoHistorico[]
  diagnosticosComerciais DiagnosticoComercial[]
  propostasComerciais    PropostaComercial[]
  handoffsComerciais     HandoffComercial[]
  contratos              Contrato[]
  ordensServico          OrdemServico[]
  entregaveis            Entregavel[]
  pendenciasCampo        PendenciaCampo[]
  evidenciasCampo        EvidenciaCampo[]

  @@index([tenantId, ativo])
  @@index([tenantId, estado, cidade])
  @@map("empreendimentos")
}

model EmpreendimentoAcesso {
  usuarioId        String   @map("usuario_id")
  empreendimentoId String   @map("empreendimento_id")
  criadoEm         DateTime @default(now()) @map("criado_em")
  criadoPorId      String?  @map("criado_por_id")

  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id])

  @@id([usuarioId, empreendimentoId])
  @@index([empreendimentoId])
  @@map("empreendimento_acessos")
}

// ─────────────────────────────────────────────────────────────────────────────
// G4 — CATÁLOGOS DE CONFIGURAÇÃO
// ─────────────────────────────────────────────────────────────────────────────

model OrgaoRegulador {
  id        String            @id @default(uuid())
  tenantId  String            @map("tenant_id")
  nome      String
  sigla     String
  esfera    EsferaRegulatoria
  tipo      TipoOrgao
  estadoUf  String?           @map("estado_uf") @db.Char(2)
  municipio String?
  site      String?
  ativo     Boolean           @default(true)
  criadoEm  DateTime          @default(now()) @map("criado_em")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  tiposProcesso TipoProcesso[]
  processos     Processo[]

  @@unique([tenantId, sigla, estadoUf, municipio])
  @@index([tenantId, esfera, ativo])
  @@map("orgaos_reguladores")
}

model TipoProcesso {
  id                        String            @id @default(uuid())
  tenantId                  String            @map("tenant_id")
  orgaoId                   String            @map("orgao_id")
  nome                      String
  descricao                 String?
  categoria                 CategoriaProcesso
  requerRenovacao           Boolean           @default(true) @map("requer_renovacao")
  periodoValidadeAnos       Int?              @map("periodo_validade_anos")
  diasAntecedenciaRenovacao Int               @default(180) @map("dias_antecedencia_renovacao")
  diasAlerta                Int[]             @default([90, 60, 30, 15, 7]) @map("dias_alerta")
  instrucoes                String?
  ativo                     Boolean           @default(true)
  versao                    Int               @default(1)
  criadoEm                  DateTime          @default(now()) @map("criado_em")
  atualizadoEm              DateTime          @updatedAt @map("atualizado_em")

  tenant     Tenant                  @relation(fields: [tenantId], references: [id])
  orgao      OrgaoRegulador          @relation(fields: [orgaoId], references: [id])
  fases      FaseTipoProcesso[]
  requisitos RequisitoTipoProcesso[]
  processos  Processo[]

  @@index([tenantId, orgaoId, ativo])
  @@map("tipos_processo")
}

model FaseTipoProcesso {
  id             String  @id @default(uuid())
  tipoProcessoId String  @map("tipo_processo_id")
  nome           String
  descricao      String?
  ordem          Int
  obrigatoria    Boolean @default(true)
  diasEstimados  Int?    @map("dias_estimados")
  instrucoes     String?

  tipoProcesso       TipoProcesso            @relation(fields: [tipoProcessoId], references: [id])
  requisitos         RequisitoTipoProcesso[]
  requisitosProcesso RequisitoProcesso[]
  historicoFases     HistoricoFaseProcesso[]

  @@unique([tipoProcessoId, ordem])
  @@map("fases_tipo_processo")
}

model TipoDocumento {
  id                 String             @id @default(uuid())
  tenantId           String             @map("tenant_id")
  codigo             String? // slug estável para portal (ex: "contrato_social")
  nome               String
  descricao          String?
  descricaoCliente   String?            @map("descricao_cliente") // texto seguro para mostrar ao cliente no portal
  momento            MomentoDocumento? // categoriza no ciclo de vida do processo (antes/durante/apos)
  categoria          CategoriaDocumento
  formatosAceitos    String[]           @default(["pdf"]) @map("formatos_aceitos")
  tamanhoMaximoMb    Int                @default(20) @map("tamanho_maximo_mb")
  temValidade        Boolean            @default(true) @map("tem_validade")
  validadeMediaMeses Int?               @map("validade_media_meses")
  exigeAssinatura    Boolean            @default(false) @map("exige_assinatura")
  instrucoesObtencao String?            @map("instrucoes_obtencao")
  ativo              Boolean            @default(true)
  criadoEm           DateTime           @default(now()) @map("criado_em")
  atualizadoEm       DateTime           @updatedAt @map("atualizado_em")

  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  requisitos         RequisitoTipoProcesso[]
  documentos         Documento[]
  requisitosProcesso RequisitoProcesso[]

  @@unique([tenantId, nome])
  @@unique([tenantId, codigo])
  @@index([tenantId, ativo])
  @@index([tenantId, momento])
  @@map("tipos_documento")
}

model RequisitoTipoProcesso {
  id                  String  @id @default(uuid())
  tipoProcessoId      String  @map("tipo_processo_id")
  tipoDocumentoId     String  @map("tipo_documento_id")
  faseTipoProcessoId  String? @map("fase_tipo_processo_id")
  obrigatorio         Boolean @default(true)
  descricaoEspecifica String? @map("descricao_especifica")
  condicoes           Json? // {"operador": "E", "regras": [...]}
  ordem               Int     @default(0)

  tipoProcesso     TipoProcesso      @relation(fields: [tipoProcessoId], references: [id])
  tipoDocumento    TipoDocumento     @relation(fields: [tipoDocumentoId], references: [id])
  faseTipoProcesso FaseTipoProcesso? @relation(fields: [faseTipoProcessoId], references: [id])

  @@index([tipoProcessoId, faseTipoProcessoId])
  @@map("requisitos_tipo_processo")
}

// ─────────────────────────────────────────────────────────────────────────────
// G5 — PROCESSOS REGULATÓRIOS (instâncias)
// ─────────────────────────────────────────────────────────────────────────────

model Processo {
  id                  String         @id @default(uuid())
  tenantId            String         @map("tenant_id")
  empreendimentoId    String         @map("empreendimento_id")
  tipoProcessoId      String         @map("tipo_processo_id")
  orgaoId             String         @map("orgao_id")
  status              StatusProcesso @default(EM_ELABORACAO)
  faseAtualOrdem      Int            @default(1) @map("fase_atual_ordem")
  numeroProtocolo     String?        @map("numero_protocolo")
  numeroLicenca       String?        @map("numero_licenca")
  dataAbertura        DateTime?      @map("data_abertura") @db.Date
  dataProtocolo       DateTime?      @map("data_protocolo") @db.Date
  dataDecisao         DateTime?      @map("data_decisao") @db.Date
  dataEmissao         DateTime?      @map("data_emissao") @db.Date
  dataVencimento      DateTime?      @map("data_vencimento") @db.Date
  dataInicioRenovacao DateTime?      @map("data_inicio_renovacao") @db.Date
  responsavelId       String?        @map("responsavel_id")
  observacoes         String?
  metadados           Json?
  criadoEm            DateTime       @default(now()) @map("criado_em")
  atualizadoEm        DateTime       @updatedAt @map("atualizado_em")

  empreendimento Empreendimento          @relation(fields: [empreendimentoId], references: [id])
  tipoProcesso   TipoProcesso            @relation(fields: [tipoProcessoId], references: [id])
  orgao          OrgaoRegulador          @relation(fields: [orgaoId], references: [id])
  responsavel    Usuario?                @relation(fields: [responsavelId], references: [id])
  requisitos     RequisitoProcesso[]
  condicionantes Condicionante[]
  tarefas        Tarefa[]
  documentos     Documento[]
  historicoFases HistoricoFaseProcesso[]

  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, dataVencimento, status])
  @@index([tenantId, responsavelId, status])
  @@map("processos")
}

model HistoricoFaseProcesso {
  id                 String    @id @default(uuid())
  processoId         String    @map("processo_id")
  faseTipoProcessoId String    @map("fase_tipo_processo_id")
  ordemFase          Int       @map("ordem_fase")
  nomeFase           String    @map("nome_fase") // snapshot imutável
  iniciouEm          DateTime  @default(now()) @map("iniciou_em")
  concluiuEm         DateTime? @map("concluiu_em")
  avancadoPorId      String    @map("avancado_por_id")
  observacoes        String?

  processo         Processo         @relation(fields: [processoId], references: [id])
  faseTipoProcesso FaseTipoProcesso @relation(fields: [faseTipoProcessoId], references: [id])
  avancadoPor      Usuario          @relation(fields: [avancadoPorId], references: [id])

  @@index([processoId, ordemFase])
  @@map("historico_fases_processo")
}

model RequisitoProcesso {
  id                 String          @id @default(uuid())
  processoId         String          @map("processo_id")
  tipoDocumentoId    String          @map("tipo_documento_id")
  requisitoTipoId    String?         @map("requisito_tipo_id")
  faseTipoProcessoId String?         @map("fase_tipo_processo_id")
  documentoId        String?         @map("documento_id")
  descricao          String?
  obrigatorio        Boolean         @default(true)
  status             StatusDocumento @default(PENDENTE)
  dispensadoPorId    String?         @map("dispensado_por_id")
  motivoDispensa     String?         @map("motivo_dispensa")
  dispensadoEm       DateTime?       @map("dispensado_em")
  ordem              Int             @default(0)
  criadoEm           DateTime        @default(now()) @map("criado_em")
  atualizadoEm       DateTime        @updatedAt @map("atualizado_em")

  processo         Processo          @relation(fields: [processoId], references: [id])
  tipoDocumento    TipoDocumento     @relation(fields: [tipoDocumentoId], references: [id])
  faseTipoProcesso FaseTipoProcesso? @relation(fields: [faseTipoProcessoId], references: [id])
  documento        Documento?        @relation("RequisitoDocumento", fields: [documentoId], references: [id])
  dispensadoPor    Usuario?          @relation(fields: [dispensadoPorId], references: [id])

  @@index([processoId, status])
  @@index([processoId, faseTipoProcessoId])
  @@map("requisitos_processo")
}

// ─────────────────────────────────────────────────────────────────────────────
// G6 — DOCUMENTOS (com referência circular gerenciada)
// ─────────────────────────────────────────────────────────────────────────────

model Documento {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  empreendimentoId String          @map("empreendimento_id")
  processoId       String?         @map("processo_id")
  condicionanteId  String?         @map("condicionante_id")
  tipoDocumentoId  String          @map("tipo_documento_id")
  nome             String
  descricao        String?
  status           StatusDocumento @default(PENDENTE)
  dataEmissao      DateTime?       @map("data_emissao") @db.Date
  dataValidade     DateTime?       @map("data_validade") @db.Date
  orgaoEmissor     String?         @map("orgao_emissor")
  versaoAtualId    String?         @unique @map("versao_atual_id")
  totalVersoes     Int             @default(0) @map("total_versoes")
  alertaDiasAntes  Int[]           @map("alerta_dias_antes")
  criadoEm         DateTime        @default(now()) @map("criado_em")
  atualizadoEm     DateTime        @updatedAt @map("atualizado_em")

  empreendimento          Empreendimento         @relation(fields: [empreendimentoId], references: [id])
  processo                Processo?              @relation(fields: [processoId], references: [id])
  condicionante           Condicionante?         @relation("DocumentoCondicionante", fields: [condicionanteId], references: [id])
  tipoDocumento           TipoDocumento          @relation(fields: [tipoDocumentoId], references: [id])
  // Referência circular — FK adicionada após criação da tabela documento_versoes
  versaoAtual             DocumentoVersao?       @relation("VersaoAtualDoDocumento", fields: [versaoAtualId], references: [id])
  versoes                 DocumentoVersao[]      @relation("VersoesDoDocumento")
  requisitos              RequisitoProcesso[]    @relation("RequisitoDocumento")
  condicionantesEvidencia Condicionante[]        @relation("EvidenciaCondicionante")
  ciclosEvidencia         CicloCondicionante[]   @relation("EvidenciaCiclo")
  pgrsDocumento           PGRS[]                 @relation("PGRSDocumento")
  pgrsEvidencias          PGRSEvidencia[]        @relation("PGRSEvidenciaDocumento")
  equipHistDocumentos     EquipamentoHistorico[] @relation("EquipHistDocumento")

  @@index([tenantId, empreendimentoId])
  @@index([tenantId, dataValidade, status])
  @@index([tenantId, processoId])
  @@map("documentos")
}

model DocumentoVersao {
  id               String                @id @default(uuid())
  documentoId      String                @map("documento_id")
  numeroVersao     Int                   @map("numero_versao")
  arquivoChaveS3   String                @map("arquivo_chave_s3")
  arquivoNome      String                @map("arquivo_nome")
  arquivoMime      String                @map("arquivo_mime")
  arquivoBytes     BigInt                @map("arquivo_bytes")
  hashSha256       String                @map("hash_sha256")
  status           StatusVersaoDocumento @default(AGUARDANDO_UPLOAD)
  observacoesEnvio String?               @map("observacoes_envio")
  enviadoPorId     String                @map("enviado_por_id")
  enviadoEm        DateTime              @default(now()) @map("enviado_em")
  validadoPorId    String?               @map("validado_por_id")
  validadoEm       DateTime?             @map("validado_em")
  motivoRejeicao   String?               @map("motivo_rejeicao")
  criadoEm         DateTime              @default(now()) @map("criado_em")

  documento      Documento         @relation("VersoesDoDocumento", fields: [documentoId], references: [id])
  enviadoPor     Usuario           @relation("VersaoEnviador", fields: [enviadoPorId], references: [id])
  validadoPor    Usuario?          @relation("VersaoValidador", fields: [validadoPorId], references: [id])
  documentoAtual Documento?        @relation("VersaoAtualDoDocumento")
  evidencias     EvidenciaTarefa[]

  @@unique([documentoId, numeroVersao])
  @@index([documentoId, status])
  @@map("documento_versoes")
}

// ─────────────────────────────────────────────────────────────────────────────
// G7 — CONDICIONANTES
// ─────────────────────────────────────────────────────────────────────────────

model Condicionante {
  id                   String                     @id @default(uuid())
  tenantId             String                     @map("tenant_id")
  empreendimentoId     String                     @map("empreendimento_id")
  processoId           String?                    @map("processo_id")
  descricao            String
  numeroCondicionante  String?                    @map("numero_condicionante")
  tipo                 TipoCondicionante
  status               StatusCondicionante        @default(PENDENTE)
  periodicidade        PeriodicidadeCondicionante @default(UNICA)
  intervaloDias        Int?                       @map("intervalo_dias")
  prazoCumprimento     DateTime?                  @map("prazo_cumprimento") @db.Date
  proximoVencimento    DateTime?                  @map("proximo_vencimento") @db.Date
  evidenciaExigida     String?                    @map("evidencia_exigida")
  documentoEvidenciaId String?                    @map("documento_evidencia_id")
  responsavelId        String?                    @map("responsavel_id")
  gerarTarefaAuto      Boolean                    @default(true) @map("gerar_tarefa_auto")
  diasAlertaAntes      Int[]                      @default([30, 15, 7]) @map("dias_alerta_antes")
  cumpridaEm           DateTime?                  @map("cumprida_em")
  dispensadoPorId      String?                    @map("dispensado_por_id")
  motivoDispensa       String?                    @map("motivo_dispensa")
  dispensadoEm         DateTime?                  @map("dispensado_em")
  criadoEm             DateTime                   @default(now()) @map("criado_em")
  atualizadoEm         DateTime                   @updatedAt @map("atualizado_em")

  empreendimento       Empreendimento       @relation(fields: [empreendimentoId], references: [id])
  processo             Processo?            @relation(fields: [processoId], references: [id])
  documentoEvidencia   Documento?           @relation("EvidenciaCondicionante", fields: [documentoEvidenciaId], references: [id])
  responsavel          Usuario?             @relation("CondicionanteResponsavel", fields: [responsavelId], references: [id])
  dispensadoPor        Usuario?             @relation("CondicionanteDispensadaPor", fields: [dispensadoPorId], references: [id])
  tarefas              Tarefa[]
  ciclos               CicloCondicionante[]
  documentosVinculados Documento[]          @relation("DocumentoCondicionante")

  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, status, proximoVencimento])
  @@index([processoId, status])
  @@map("condicionantes")
}

model CicloCondicionante {
  id                   String              @id @default(uuid())
  condicionanteId      String              @map("condicionante_id")
  numeroCiclo          Int                 @map("numero_ciclo")
  periodoInicio        DateTime            @map("periodo_inicio") @db.Date
  periodoFim           DateTime            @map("periodo_fim") @db.Date
  status               StatusCondicionante @default(PENDENTE)
  documentoEvidenciaId String?             @map("documento_evidencia_id")
  observacoes          String?
  cumpridoEm           DateTime?           @map("cumprido_em")
  cumpridoPorId        String?             @map("cumprido_por_id")
  criadoEm             DateTime            @default(now()) @map("criado_em")

  condicionante      Condicionante @relation(fields: [condicionanteId], references: [id])
  documentoEvidencia Documento?    @relation("EvidenciaCiclo", fields: [documentoEvidenciaId], references: [id])
  cumpridoPor        Usuario?      @relation(fields: [cumpridoPorId], references: [id])
  tarefas            Tarefa[]

  @@unique([condicionanteId, numeroCiclo])
  @@index([condicionanteId, status])
  @@map("ciclos_condicionante")
}

// ─────────────────────────────────────────────────────────────────────────────
// G8 — TAREFAS
// ─────────────────────────────────────────────────────────────────────────────

model Tarefa {
  id                   String           @id @default(uuid())
  tenantId             String           @map("tenant_id")
  empreendimentoId     String           @map("empreendimento_id")
  processoId           String?          @map("processo_id")
  condicionanteId      String?          @map("condicionante_id")
  cicloCondicionanteId String?          @map("ciclo_condicionante_id")
  documentoId          String?          @map("documento_id")
  titulo               String
  descricao            String?
  status               StatusTarefa     @default(PENDENTE)
  prioridade           PrioridadeTarefa @default(MEDIA)
  origem               OrigemTarefa     @default(MANUAL)
  regraOrigemId        String?          @map("regra_origem_id") // sem FK formal
  responsavelId        String?          @map("responsavel_id")
  criadorId            String           @map("criador_id")
  dataVencimento       DateTime?        @map("data_vencimento")
  dataConclusao        DateTime?        @map("data_conclusao")
  dataEscalonamento    DateTime?        @map("data_escalonamento")
  escaladoParaId       String?          @map("escalado_para_id")
  observacoesConclusao String?          @map("observacoes_conclusao")
  metadados            Json?
  scoreCriticidade     Int              @default(0) @map("score_criticidade")
  criadoEm             DateTime         @default(now()) @map("criado_em")
  atualizadoEm         DateTime         @updatedAt @map("atualizado_em")

  empreendimento     Empreendimento      @relation(fields: [empreendimentoId], references: [id])
  processo           Processo?           @relation(fields: [processoId], references: [id])
  condicionante      Condicionante?      @relation(fields: [condicionanteId], references: [id])
  cicloCondicionante CicloCondicionante? @relation(fields: [cicloCondicionanteId], references: [id])
  responsavel        Usuario?            @relation("TarefaResponsavel", fields: [responsavelId], references: [id])
  criador            Usuario             @relation("TarefaCriador", fields: [criadorId], references: [id])
  escaladoPara       Usuario?            @relation("TarefaEscalonada", fields: [escaladoParaId], references: [id])
  evidencias         EvidenciaTarefa[]
  dependencias       TarefaDependencia[] @relation("TarefaPrincipal")
  dependeDe          TarefaDependencia[] @relation("TarefaDependente")

  @@index([tenantId, responsavelId, status])
  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, dataVencimento, status])
  @@index([tenantId, prioridade, status])
  @@index([tenantId, scoreCriticidade(sort: Desc), status])
  @@map("tarefas")
}

model TarefaDependencia {
  tarefaId    String @map("tarefa_id")
  dependeDeId String @map("depende_de_id")

  tarefa    Tarefa @relation("TarefaPrincipal", fields: [tarefaId], references: [id])
  dependeDe Tarefa @relation("TarefaDependente", fields: [dependeDeId], references: [id])

  @@id([tarefaId, dependeDeId])
  @@index([dependeDeId])
  @@map("tarefas_dependencias")
}

model EvidenciaTarefa {
  id                String        @id @default(uuid())
  tarefaId          String        @map("tarefa_id")
  tipo              TipoEvidencia
  descricao         String?
  documentoVersaoId String?       @map("documento_versao_id")
  arquivoChaveS3    String?       @map("arquivo_chave_s3")
  arquivoNome       String?       @map("arquivo_nome")
  textoLivre        String?       @map("texto_livre")
  url               String?
  enviadoPorId      String        @map("enviado_por_id")
  criadoEm          DateTime      @default(now()) @map("criado_em")

  tarefa          Tarefa           @relation(fields: [tarefaId], references: [id])
  documentoVersao DocumentoVersao? @relation(fields: [documentoVersaoId], references: [id])

  @@index([tarefaId])
  @@map("evidencias_tarefas")
}

// ─────────────────────────────────────────────────────────────────────────────
// G9 — AUTOMAÇÃO
// ─────────────────────────────────────────────────────────────────────────────

model RegraAutomatica {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  nome               String
  descricao          String?
  tipo               String // vencimento_doc | vencimento_proc | condicionante | requisito | escalamento
  gatilho            Json // { entidade, campo_data, dias_antes, status_alvo }
  acao               String // criar_tarefa | enviar_alerta | escalonar
  parametros         Json // parâmetros da ação
  ativo              Boolean  @default(true)
  escopo             String   @default("global")
  escopoReferenciaId String?  @map("escopo_referencia_id")
  ordemExecucao      Int      @default(100) @map("ordem_execucao")
  criadoEm           DateTime @default(now()) @map("criado_em")
  atualizadoEm       DateTime @updatedAt @map("atualizado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, ativo, tipo])
  @@index([tenantId, ativo, ordemExecucao])
  @@map("regras_automaticas")
}

// ─────────────────────────────────────────────────────────────────────────────
// G10 — ALERTAS E NOTIFICAÇÕES
// ─────────────────────────────────────────────────────────────────────────────

model Alerta {
  id               String      @id @default(uuid())
  tenantId         String      @map("tenant_id")
  empreendimentoId String?     @map("empreendimento_id")
  tipo             TipoAlerta
  nivel            NivelAlerta
  titulo           String
  mensagem         String
  entidadeTipo     String?     @map("entidade_tipo")
  entidadeId       String?     @map("entidade_id")
  dados            Json?
  emailEnviado     Boolean     @default(false) @map("email_enviado")
  emailEnviadoEm   DateTime?   @map("email_enviado_em")
  wppEnviado       Boolean     @default(false) @map("wpp_enviado")
  wppEnviadoEm     DateTime?   @map("wpp_enviado_em")
  criadoEm         DateTime    @default(now()) @map("criado_em")

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  empreendimento Empreendimento?      @relation(fields: [empreendimentoId], references: [id])
  destinatarios  AlertaDestinatario[]

  @@index([tenantId, nivel, criadoEm])
  @@index([tenantId, empreendimentoId, criadoEm])
  @@map("alertas")
}

model AlertaDestinatario {
  alertaId  String    @map("alerta_id")
  usuarioId String    @map("usuario_id")
  lido      Boolean   @default(false)
  lidoEm    DateTime? @map("lido_em")
  canais    String[]

  alerta  Alerta  @relation(fields: [alertaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@id([alertaId, usuarioId])
  @@index([usuarioId, lido])
  @@map("alertas_destinatarios")
}

// ─────────────────────────────────────────────────────────────────────────────
// G11 — COMPLIANCE
// ─────────────────────────────────────────────────────────────────────────────

model ComplianceSnapshot {
  id                      String           @id @default(uuid())
  tenantId                String           @map("tenant_id")
  empreendimentoId        String           @map("empreendimento_id")
  indiceConformidade      Decimal          @map("indice_conformidade") @db.Decimal(5, 2)
  statusCompliance        StatusCompliance @map("status_compliance")
  documentosValidos       Int              @map("documentos_validos")
  documentosTotal         Int              @map("documentos_total")
  processosRegulares      Int              @map("processos_regulares")
  processosTotal          Int              @map("processos_total")
  condicionantesCumpridas Int              @map("condicionantes_cumpridas")
  condicionantesAtivas    Int              @map("condicionantes_ativas")
  detalhes                Json?
  calculadoEm             DateTime         @default(now()) @map("calculado_em")

  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id])

  @@index([tenantId, empreendimentoId, calculadoEm(sort: Desc)])
  @@index([tenantId, statusCompliance, calculadoEm(sort: Desc)])
  @@map("compliance_snapshots")
}

// ─────────────────────────────────────────────────────────────────────────────
// G12 — AUDITORIA (IMUTÁVEL — sem FKs para sobreviver à deleção de entidades)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id") // TEXT, não FK
  usuarioId     String?  @map("usuario_id") // sem FK
  usuarioNome   String?  @map("usuario_nome")
  usuarioEmail  String?  @map("usuario_email")
  usuarioPerfil String?  @map("usuario_perfil")
  acao          String // ex: "documento.versao.aprovada"
  entidadeTipo  String   @map("entidade_tipo")
  entidadeId    String   @map("entidade_id")
  dadosAntes    Json?    @map("dados_antes")
  dadosDepois   Json?    @map("dados_depois")
  ipOrigem      String?  @map("ip_origem")
  userAgent     String?  @map("user_agent")
  contexto      Json? // { empreendimentoId, processoId, etc. }
  criadoEm      DateTime @default(now()) @map("criado_em")

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([tenantId, entidadeTipo, entidadeId, criadoEm(sort: Desc)])
  @@index([tenantId, criadoEm(sort: Desc)])
  @@index([tenantId, entidadeTipo])
  @@index([tenantId, usuarioId, criadoEm(sort: Desc)])
  @@index([criadoEm(sort: Desc)]) // Para limpeza por período
  @@map("audit_log")
}

model IntegracaoEvento {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  sourceSystem     String    @map("source_system")
  eventName        String    @map("event_name")
  idempotencyKey   String    @map("idempotency_key")
  payloadJson      Json      @map("payload_json")
  status           String    @default("received")
  processedAt      DateTime? @map("processed_at")
  errorMessage     String?   @map("error_message")
  empresaId        String?   @map("empresa_id")
  empreendimentoId String?   @map("empreendimento_id")
  tarefaId         String?   @map("tarefa_id")
  criadoEm         DateTime  @default(now()) @map("criado_em")
  atualizadoEm     DateTime  @updatedAt @map("atualizado_em")

  @@unique([tenantId, sourceSystem, idempotencyKey])
  @@index([tenantId, status, criadoEm(sort: Desc)])
  @@index([sourceSystem, eventName, criadoEm(sort: Desc)])
  @@map("integracao_eventos")
}

// ─────────────────────────────────────────────────────────────────────────────
// M1 — GESTÃO AMBIENTAL: LICENÇAS + CONDICIONANTES
// ─────────────────────────────────────────────────────────────────────────────

model LicencaAmbiental {
  id                 String               @id @default(uuid())
  tenantId           String               @map("tenant_id")
  empreendimentoId   String               @map("empreendimento_id")
  tipo               TipoLicencaAmbiental
  numero             String
  orgaoEmissor       String               @map("orgao_emissor")
  responsavelTecnico String?              @map("responsavel_tecnico")
  dataEmissao        DateTime             @map("data_emissao") @db.Date
  dataVencimento     DateTime             @map("data_vencimento") @db.Date
  status             StatusLicenca        @default(VIGENTE)
  chaveS3            String?              @map("chave_s3")
  nomeArquivo        String?              @map("nome_arquivo")
  observacoes        String?
  diasAlerta         Int[]                @default([90, 60, 30, 15, 7]) @map("dias_alerta")
  analiseIA          Json?                @map("analise_ia")
  analisadoEm        DateTime?            @map("analisado_em")
  criadoEm           DateTime             @default(now()) @map("criado_em")
  atualizadoEm       DateTime             @updatedAt @map("atualizado_em")

  empreendimento Empreendimento    @relation(fields: [empreendimentoId], references: [id])
  condicoes      CondicaoLicenca[]

  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, dataVencimento, status])
  @@map("licencas_ambientais")
}

model CondicaoLicenca {
  id           String    @id @default(uuid())
  licencaId    String    @map("licenca_id")
  numero       String?
  descricao    String
  prazo        DateTime? @db.Date
  status       String    @default("PENDENTE") // PENDENTE | EM_CUMPRIMENTO | CUMPRIDA | VENCIDA
  comprovante  String? // chave S3
  observacoes  String?
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  licenca LicencaAmbiental @relation(fields: [licencaId], references: [id], onDelete: Cascade)

  @@index([licencaId, status])
  @@map("condicoes_licenca")
}

// ─────────────────────────────────────────────────────────────────────────────
// M4 — REGULATÓRIO URBANO: AVCB, ALVARÁ, HABITE-SE
// ─────────────────────────────────────────────────────────────────────────────

model AlvaraUrbanistico {
