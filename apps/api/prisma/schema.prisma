// ─────────────────────────────────────────────────────────────────────────────
// REGPOSTO — Schema Prisma
// Geração: prisma generate
// Migrations: prisma migrate dev
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // "native" para dev local; o target musl é o engine do Alpine usado nas imagens Docker
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

