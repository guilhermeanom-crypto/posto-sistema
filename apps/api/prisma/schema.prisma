  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, nomeParametro, tipoMedio])
  @@index([tenantId, tipoMedio])
  @@map("limites_parametros")
}

model CampanhaMonitoramento {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  empreendimentoId    String   @map("empreendimento_id")
  pocoMonitoramentoId String?  @map("poco_monitoramento_id")
  tipo                String // SOLO | AGUA_SUBTERRANEA | VAPOR | AR
  dataColeta          DateTime @map("data_coleta") @db.Date
  laboratorio         String
  resultado           String   @default("CONFORME") // CONFORME | ATENCAO | NAO_CONFORME
  chaveS3             String?  @map("chave_s3")
  nomeArquivo         String?  @map("nome_arquivo")
  observacoes         String?
  criadoEm            DateTime @default(now()) @map("criado_em")
  atualizadoEm        DateTime @updatedAt @map("atualizado_em")

  empreendimento    Empreendimento          @relation(fields: [empreendimentoId], references: [id])
  pocoMonitoramento PocoMonitoramento?      @relation(fields: [pocoMonitoramentoId], references: [id])
  parametros        ParametroContaminante[]

  @@index([tenantId, empreendimentoId, resultado])
  @@index([tenantId, dataColeta])
  @@map("campanhas_monitoramento")
