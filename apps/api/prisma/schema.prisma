// ─────────────────────────────────────────────────────────────────────────────
// M6-B — HISTÓRICO TÉCNICO DE EQUIPAMENTOS (Tanques + Bombas)
// ─────────────────────────────────────────────────────────────────────────────

enum TipoEquipamento {
  TANQUE
  BOMBA
  LINHA
  SENSOR
  CAIXA_SEPARADORA
  SRV
  OUTROS
}

enum TipoEventoEquipamento {
  MANUTENCAO_PREVENTIVA
  MANUTENCAO_CORRETIVA
  CALIBRACAO
  SUBSTITUICAO
  OCORRENCIA
  DESATIVACAO
  REATIVACAO
  INSTALACAO
  VISTORIA
}

model EquipamentoHistorico {
  id               String                @id @default(uuid())
  tenantId         String                @map("tenant_id")
  empreendimentoId String                @map("empreendimento_id")
  equipamentoTipo  TipoEquipamento       @map("equipamento_tipo")
  equipamentoId    String                @map("equipamento_id") // ID do Tanque ou Bomba
  tipoEvento       TipoEventoEquipamento @map("tipo_evento")
  dataEvento       DateTime              @map("data_evento") @db.Date
  descricao        String
  responsavel      String?
  custo            Decimal?              @db.Decimal(12, 2)
  documentoId      String?               @map("documento_id")
  observacoes      String?
  criadoPorId      String                @map("criado_por_id")
  criadoEm         DateTime              @default(now()) @map("criado_em")

  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id])
  criadoPor      Usuario        @relation("EquipHistCriador", fields: [criadoPorId], references: [id])
  documento      Documento?     @relation("EquipHistDocumento", fields: [documentoId], references: [id])

  @@index([tenantId, equipamentoTipo, equipamentoId])
  @@index([tenantId, empreendimentoId, dataEvento])
  @@map("equipamentos_historico")
}

// ─────────────────────────────────────────────────────────────────────────────
// M9 — ESTANQUEIDADE / SASC / TANQUES
// ─────────────────────────────────────────────────────────────────────────────

model Tanque {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  empreendimentoId String    @map("empreendimento_id")
  numero           Int
  capacidadeLitros Int       @map("capacidade_litros")
  combustivel      String
  material         String? // FIBRA | ACO | DUPLA_PAREDE
  dataInstalacao   DateTime? @map("data_instalacao") @db.Date
  status           String    @default("ATIVO") // ATIVO | INATIVO | INTERDITADO | REMOVIDO
  observacoes      String?
  criadoEm         DateTime  @default(now()) @map("criado_em")
  atualizadoEm     DateTime  @updatedAt @map("atualizado_em")

  empreendimento Empreendimento       @relation(fields: [empreendimentoId], references: [id])
  testes         TesteEstanqueidade[]

  @@unique([empreendimentoId, numero])
  @@index([tenantId, empreendimentoId, status])
  @@map("tanques")
}

model TesteEstanqueidade {
  id           String   @id @default(uuid())
  tanqueId     String   @map("tanque_id")
  empresa      String
  responsavel  String?
  dataExecucao DateTime @map("data_execucao") @db.Date
  resultado    String // APROVADO | REPROVADO | INCONCLUSIVO
  metodo       String? // vácuo, pressão, etc.
  proximoTeste DateTime @map("proximo_teste") @db.Date
  chaveS3      String?  @map("chave_s3")
  nomeArquivo  String?  @map("nome_arquivo")
  observacoes  String?
  criadoEm     DateTime @default(now()) @map("criado_em")

  tanque Tanque @relation(fields: [tanqueId], references: [id], onDelete: Restrict)

  @@index([tanqueId, dataExecucao])
  @@map("testes_estanqueidade")
}

// ─────────────────────────────────────────────────────────────────────────────
// M2 — LOGÍSTICA REVERSA: MTR + TRANSPORTADORAS
// ─────────────────────────────────────────────────────────────────────────────

model Transportadora {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  nome             String
  cnpj             String
  licencaAmbiental String?   @map("licenca_ambiental")
  validadeLicenca  DateTime? @map("validade_licenca") @db.Date
  telefone         String?
  email            String?
  ativo            Boolean   @default(true)
  criadoEm         DateTime  @default(now()) @map("criado_em")
  atualizadoEm     DateTime  @updatedAt @map("atualizado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  mtrs   MTR[]

  @@unique([tenantId, cnpj])
  @@index([tenantId, ativo])
  @@map("transportadoras")
}

model MTR {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  empreendimentoId String    @map("empreendimento_id")
  transportadoraId String?   @map("transportadora_id")
  numeroMTR        String?   @map("numero_mtr")
  dataEmissao      DateTime  @map("data_emissao") @db.Date
  dataColeta       DateTime? @map("data_coleta") @db.Date
  residuos         Json // [{ tipo, quantidade, unidade, destinacao }]
  status           String    @default("ABERTO") // ABERTO | COLETADO | DESTINADO | ENCERRADO
  certidaoS3       String?   @map("certidao_s3")
  observacoes      String?
  criadoEm         DateTime  @default(now()) @map("criado_em")
  atualizadoEm     DateTime  @updatedAt @map("atualizado_em")

  empreendimento Empreendimento  @relation(fields: [empreendimentoId], references: [id])
  transportadora Transportadora? @relation(fields: [transportadoraId], references: [id])
  ccrs           CCR[]

  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, dataEmissao])
  @@index([tenantId, status, dataEmissao])
  @@index([transportadoraId, status])
  @@map("mtrs")
}

model MetaResiduoAnual {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  empreendimentoId String   @map("empreendimento_id")
  ano              Int
  tipoResiduo      String   @map("tipo_residuo") // ex: OLEO_LUBRIFICANTE | FILTRO_OLEO | PNEU | EMBALAGEM | OUTROS
  unidade          String // KG | LITRO | UNIDADE | TON
  metaQuantidade   Decimal  @map("meta_quantidade") @db.Decimal(12, 3)
  observacoes      String?
  criadoEm         DateTime @default(now()) @map("criado_em")
  atualizadoEm     DateTime @updatedAt @map("atualizado_em")

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id])

  @@unique([tenantId, empreendimentoId, ano, tipoResiduo])
  @@index([tenantId, empreendimentoId, ano])
  @@map("metas_residuos_anuais")
}

model CCR {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  mtrId          String   @map("mtr_id")
  numeroCCR      String?  @map("numero_ccr")
  tipoResiduo    String   @map("tipo_residuo")
  quantidadeKg   Decimal  @map("quantidade_kg") @db.Decimal(12, 3)
  destinador     String // razão social do destinador final
  cnpjDestinador String?  @map("cnpj_destinador")
  dataDestinacao DateTime @map("data_destinacao") @db.Date
  tecnologiaUso  String?  @map("tecnologia_uso") // COPROCESSAMENTO | RECICLAGEM | INCINERACAO | ATERRO | OUTROS
  arquivoS3      String?  @map("arquivo_s3")
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  mtr    MTR    @relation(fields: [mtrId], references: [id], onDelete: Cascade)

  @@index([tenantId, mtrId])
  @@index([tenantId, dataDestinacao])
  @@map("ccrs")
}

// ─────────────────────────────────────────────────────────────────────────────
// M4-B — PGRS (Plano de Gerenciamento de Resíduos Sólidos)
// ─────────────────────────────────────────────────────────────────────────────

enum StatusPGRS {
  EM_ELABORACAO
  VIGENTE
  A_RENOVAR
  VENCIDO
  CANCELADO
}

enum StatusPGRSExigencia {
  PENDENTE
  EM_CUMPRIMENTO
  COMPROVADO
  VENCIDO
  NAO_APLICAVEL
}

model PGRS {
  id                 String     @id @default(uuid())
  tenantId           String     @map("tenant_id")
  empreendimentoId   String     @map("empreendimento_id")
  versao             String // ex: "2024-v1"
  responsavelTecnico String     @map("responsavel_tecnico")
  artNumero          String?    @map("art_numero")
  dataAprovacao      DateTime   @map("data_aprovacao") @db.Date
  dataVencimento     DateTime   @map("data_vencimento") @db.Date
  status             StatusPGRS @default(VIGENTE)
  documentoId        String?    @map("documento_id") // FK para Documento (PDF do plano)
  observacoes        String?
  criadoEm           DateTime   @default(now()) @map("criado_em")
  atualizadoEm       DateTime   @updatedAt @map("atualizado_em")

  empreendimento Empreendimento  @relation(fields: [empreendimentoId], references: [id])
  documento      Documento?      @relation("PGRSDocumento", fields: [documentoId], references: [id])
  exigencias     PGRSExigencia[]

  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, dataVencimento])
  @@map("pgrs")
}

model PGRSExigencia {
  id                        String                     @id @default(uuid())
  pgrsId                    String                     @map("pgrs_id")
  descricao                 String
  tipoResiduo               String                     @map("tipo_residuo") // OLEO_LUBRIFICANTE | FILTRO | EMBALAGEM | EFLUENTE | LODO | SOLO | OUTROS
  periodicidade             PeriodicidadeCondicionante
  prazoComprovacaoDias      Int                        @map("prazo_comprovacao_dias")
  status                    StatusPGRSExigencia        @default(PENDENTE)
  naoAplicavel              Boolean                    @default(false) @map("nao_aplicavel")
  naoAplicavelJustificativa String?                    @map("nao_aplicavel_justificativa")
  naoAplicavelPorId         String?                    @map("nao_aplicavel_por_id")
  criadoEm                  DateTime                   @default(now()) @map("criado_em")

  pgrs       PGRS            @relation(fields: [pgrsId], references: [id], onDelete: Cascade)
  evidencias PGRSEvidencia[]

  @@index([pgrsId, status])
  @@map("pgrs_exigencias")
}

model PGRSEvidencia {
  id             String   @id @default(uuid())
  exigenciaId    String   @map("exigencia_id")
  documentoId    String   @map("documento_id")
  periodoRef     String   @map("periodo_referencia") // ex: "2024-S1", "2024-T3"
  vinculadoPorId String   @map("vinculado_por_id")
  criadoEm       DateTime @default(now()) @map("criado_em")

  exigencia PGRSExigencia @relation(fields: [exigenciaId], references: [id], onDelete: Cascade)
  documento Documento     @relation("PGRSEvidenciaDocumento", fields: [documentoId], references: [id])

  @@index([exigenciaId])
  @@map("pgrs_evidencias")
}

// ─────────────────────────────────────────────────────────────────────────────
// M5 — OUTORGA HÍDRICA: POÇOS ARTESIANOS + LAUDOS
// ─────────────────────────────────────────────────────────────────────────────

model PocoArtesiano {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  empreendimentoId String    @map("empreendimento_id")
  codigo           String
  profundidade     Decimal?  @db.Decimal(8, 2) // metros
  coordenadas      String? // "lat,lng"
  outorgaDAEE      String?   @map("outorga_daee")
  validadeOutorga  DateTime? @map("validade_outorga") @db.Date
  vazaoAutorizada  Decimal?  @map("vazao_autorizada") @db.Decimal(10, 2) // m³/h
  dataPerforacao   DateTime? @map("data_perforacao") @db.Date
  status           String    @default("ATIVO") // ATIVO | INATIVO | INTERDITADO | SELADO
  observacoes      String?
  criadoEm         DateTime  @default(now()) @map("criado_em")
  atualizadoEm     DateTime  @updatedAt @map("atualizado_em")

  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id])
  laudos         LaudoAgua[]

  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, validadeOutorga])
  @@map("pocos_artesianos")
}

model LaudoAgua {
  id           String   @id @default(uuid())
  pocoId       String   @map("poco_id")
  dataCampanha DateTime @map("data_campanha") @db.Date
  laboratorio  String
  resultado    String // CONFORME | NAO_CONFORME | ATENCAO
  parametros   Json // [{ nome, valorMedido, limite, unidade, conforme }]
  chaveS3      String?  @map("chave_s3")
  nomeArquivo  String?  @map("nome_arquivo")
  observacoes  String?
  criadoEm     DateTime @default(now()) @map("criado_em")

  poco PocoArtesiano @relation(fields: [pocoId], references: [id], onDelete: Restrict)

  @@index([pocoId, dataCampanha])
  @@index([resultado, dataCampanha])
  @@map("laudos_agua")
}

// ─────────────────────────────────────────────────────────────────────────────
// M8 — MONITORAMENTO SOLO E ÁGUA SUBTERRÂNEA
