// ─────────────────────────────────────────────────────────────────────────────
// M3 — SST / SEGURANÇA DO TRABALHO
// ─────────────────────────────────────────────────────────────────────────────

model Funcionario {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  empreendimentoId String    @map("empreendimento_id")
  nome             String
  cpf              String?
  rg               String?
  dataNascimento   DateTime? @map("data_nascimento") @db.Date
  cargo            String
  setor            String? // PISTA | DESCARGA | AREA_TECNICA | CONVENIENCIA | ADMINISTRATIVO
  vinculo          String    @default("CLT") // CLT | PJ | TERCEIRIZADO | ESTAGIO | TEMPORARIO
  email            String?
  telefone         String?
  dataAdmissao     DateTime  @map("data_admissao") @db.Date
  dataDemissao     DateTime? @map("data_demissao") @db.Date
  motivoDemissao   String?   @map("motivo_demissao")
  ativo            Boolean   @default(true)
