// ─────────────────────────────────────────────────────────────────────────────
// LEADS COMERCIAIS (prospects que chegam via WhatsApp sem cadastro)
// ─────────────────────────────────────────────────────────────────────────────

model LeadWhatsApp {
  id                 String     @id @default(uuid())
  tenantId           String     @map("tenant_id")
  numero             String
  nome               String?
  empresa            String?
  quantidadePostos   Int?       @map("quantidade_postos")
  desafios           String?    @db.Text
  status             String     @default("NOVO") // NOVO | EM_CONVERSA | QUALIFICADO | DESCARTADO
  estagio            EstagioCRM @default(NOVO)
  responsavelId      String?    @map("responsavel_id")
  valorEstimado      Decimal?   @map("valor_estimado") @db.Decimal(12, 2)
  dataProximoContato DateTime?  @map("data_proximo_contato") @db.Date
  notas              String?    @db.Text
  criadoEm           DateTime   @default(now()) @map("criado_em")
  atualizadoEm       DateTime   @updatedAt @map("atualizado_em")

