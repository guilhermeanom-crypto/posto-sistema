  campanha CampanhaMonitoramento @relation(fields: [campanhaId], references: [id], onDelete: Cascade)

  @@index([campanhaId, emAlerta])
  @@map("parametros_contaminantes")
}

// ─────────────────────────────────────────────────────────────────────────────
// M7 — FISCALIZAÇÕES, AUTOS E DEFESA TÉCNICA
// ─────────────────────────────────────────────────────────────────────────────

enum StatusAutoInfracao {
  RECEBIDO
  EM_DEFESA
  AGUARDANDO_JULGAMENTO
  JULGADO_FAVORAVEL
  JULGADO_DESFAVORAVEL
  EM_RECURSO
  ENCERRADO
  PAGO
}

enum InstanciaRecurso {
  PRIMEIRA
  SEGUNDA
  TERCEIRA
  JUDICIAL
}

model AutoInfracao {
  id               String             @id @default(uuid())
  tenantId         String             @map("tenant_id")
  empreendimentoId String             @map("empreendimento_id")
  orgao            String // CETESB | ANP | INMETRO | BOMBEIROS | PREFEITURA | etc.
  numeroAuto       String             @map("numero_auto")
  dataLavratura    DateTime           @map("data_lavratura") @db.Date
  dataRecebimento  DateTime?          @map("data_recebimento") @db.Date
  artigo           String?
  descricao        String             @db.Text
  valorMulta       Decimal?           @map("valor_multa") @db.Decimal(12, 2)
  prazoDefesa      DateTime           @map("prazo_defesa") @db.Date
  status           StatusAutoInfracao @default(RECEBIDO)
  chaveS3          String?            @map("chave_s3") // PDF do auto original
  nomeArquivo      String?            @map("nome_arquivo")
  observacoes      String?
  analiseIA        Json?              @map("analise_ia")
  analisadoEm      DateTime?          @map("analisado_em")
  criadoEm         DateTime           @default(now()) @map("criado_em")
  atualizadoEm     DateTime           @updatedAt @map("atualizado_em")

  empreendimento Empreendimento          @relation(fields: [empreendimentoId], references: [id])
  recursos       RecursoAdministrativo[]
  defesas        DefesaTecnica[]

  @@index([tenantId, empreendimentoId, status])
  @@index([tenantId, prazoDefesa, status])
  @@map("autos_infracao")
}

model RecursoAdministrativo {
  id              String           @id @default(uuid())
  autoId          String           @map("auto_id")
  instancia       InstanciaRecurso
  dataProtocolo   DateTime         @map("data_protocolo") @db.Date
  prazoResposta   DateTime?        @map("prazo_resposta") @db.Date
  numeroProtocolo String?          @map("numero_protocolo")
  peticaoS3       String?          @map("peticao_s3")
  resultadoS3     String?          @map("resultado_s3")
  resultado       String? // FAVORAVEL | DESFAVORAVEL | PARCIALMENTE_FAVORAVEL | PENDENTE
  dataJulgamento  DateTime?        @map("data_julgamento") @db.Date
  observacoes     String?
  criadoEm        DateTime         @default(now()) @map("criado_em")
  atualizadoEm    DateTime         @updatedAt @map("atualizado_em")

  auto AutoInfracao @relation(fields: [autoId], references: [id], onDelete: Restrict)

  @@index([autoId])
  @@map("recursos_administrativos")
}

model DefesaTecnica {
  id            String   @id @default(uuid())
  autoId        String   @map("auto_id")
  rascunhoIA    String   @map("rascunho_ia") @db.Text
  revisaoHumana String?  @map("revisao_humana") @db.Text
  chaveS3Final  String?  @map("chave_s3_final")
  status        String   @default("RASCUNHO") // RASCUNHO | REVISADO | ENVIADO
  geradoEm      DateTime @default(now()) @map("gerado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  auto AutoInfracao @relation(fields: [autoId], references: [id], onDelete: Restrict)

  @@index([autoId])
  @@map("defesas_tecnicas")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCORE DE RISCO DE FISCALIZAÇÃO
// ─────────────────────────────────────────────────────────────────────────────

model ScoreRisco {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  empreendimentoId String   @map("empreendimento_id")
  orgao            String // CETESB | ANP | INMETRO | BOMBEIROS
  score            Int // 0-100 (maior = mais risco)
  nivel            String // BAIXO | MEDIO | ALTO | CRITICO
  fatores          Json // breakdown dos pontos adicionados
  recomendacoes    String[] // ações para reduzir o risco
  calculadoEm      DateTime @default(now()) @map("calculado_em")

  empreendimento Empreendimento @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)

  @@unique([empreendimentoId, orgao])
  @@index([tenantId, empreendimentoId])
  @@index([tenantId, nivel])
  @@map("scores_risco")
}

// ─────────────────────────────────────────────────────────────────────────────
// MONITOR DO DIÁRIO OFICIAL — publicações relevantes para postos
// ─────────────────────────────────────────────────────────────────────────────

model PublicacaoDO {
  id             String   @id @default(uuid())
  fonte          String // DOU | DOE_SP | DOE_MG | DOE_RJ
  dataPublicacao DateTime @map("data_publicacao") @db.Date
  secao          String? // Seção 1 / 2 / 3 / Extra
  titulo         String   @db.Text
  conteudo       String?  @db.Text
  url            String?
  keywordsMatch  String[] @map("keywords_match")
  relevante      Boolean  @default(false)
