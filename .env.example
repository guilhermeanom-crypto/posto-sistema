# ─────────────────────────────────────────────────────────────────────────────
# HÁBILIS POSTO — Variáveis de Ambiente
# Copie para .env e preencha antes de iniciar.
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=info

API_URL=https://api.seudominio.com.br/api/v1
WEB_URL=https://app.seudominio.com.br

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://posto:SENHA_FORTE@postgres:5432/posto_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:SENHA_REDIS@redis:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere: openssl rand -base64 64
JWT_SECRET=GERE_COM_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Integrações sistema-a-sistema ────────────────────────────────────────────
# Gere: openssl rand -base64 48
INTEGRATION_SHARED_SECRET=GERE_COM_OPENSSL_RAND_BASE64_48
TRUST_PROXY_HOPS=1

# ── Armazenamento S3 / MinIO ──────────────────────────────────────────────────
STORAGE_PROVIDER=s3
# Para MinIO auto-hospedado use: http://minio:9000
# Para AWS S3 deixe S3_ENDPOINT em branco
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=posto-documentos
S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
PRESIGNED_URL_EXPIRES_SECONDS=900

# ── E-mail (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@seudominio.com.br
EMAIL_FROM_NAME=Hábilis Posto

# ── IA — Claude API (Anthropic) ───────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-apiXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── WhatsApp via Z-API (opcional — deixe vazio para desativar) ────────────────
# https://developer.z-api.io
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── Next.js (frontend) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.seudominio.com.br/api/v1

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

# ── Infraestrutura (docker-compose.prod.yml) ──────────────────────────────────
POSTGRES_USER=posto
POSTGRES_PASSWORD=SENHA_FORTE_POSTGRES
POSTGRES_DB=posto_prod
REDIS_PASSWORD=SENHA_FORTE_REDIS
MINIO_ROOT_USER=posto_minio
MINIO_ROOT_PASSWORD=SENHA_FORTE_MINIO
